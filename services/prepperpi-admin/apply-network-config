#!/usr/bin/env python3
"""apply-network-config — privileged worker, invoked via sudo by the
prepperpi-admin FastAPI app.

Reads a JSON spec from stdin, validates strictly, writes
/boot/firmware/prepperpi.conf, and bounces the AP stack
(prepperpi-ap-configure -> hostapd -> dnsmasq) so the new settings
take effect.

This script is the trust boundary between the (unprivileged)
prepperpi-admin user and the privileged kernel/systemd surface.
Validation here MUST be independent of whatever the FastAPI app
does -- treat the FastAPI process as untrusted. The sudoers rule
that lets prepperpi-admin call this without a password covers the
whole script regardless of args; we read everything from stdin and
ignore argv.

Two action modes:
  {"action": "set", "ssid": "...", "wifi_password": "...",
                    "channel": "auto"|1..13, "country": "US"}
  {"action": "reset"}
"""
from __future__ import annotations

import json
import re
import subprocess
import sys
from pathlib import Path

CONF_FILE = Path("/boot/firmware/prepperpi.conf")

# Hard cap on the JSON payload we'll read from stdin. Legitimate
# payloads are a few hundred bytes; anything north of this is either a
# bug or an attempt to wedge the worker by holding it in stdin.read().
MAX_STDIN_BYTES = 1 << 20  # 1 MiB

# Two-letter ISO 3166-1 codes hostapd's regulatory database accepts.
# Hard-coding rather than punting to the user keeps the validation
# strict and lets us bound the surface attack a malformed code
# would have on hostapd's startup.
ALLOWED_COUNTRIES = {
    "AT", "AU", "BE", "BR", "CA", "CH", "CL", "CN", "CO", "CZ",
    "DE", "DK", "ES", "FI", "FR", "GB", "GR", "HK", "HU", "IE",
    "IL", "IN", "IS", "IT", "JP", "KR", "MX", "MY", "NL", "NO",
    "NZ", "PH", "PL", "PT", "RO", "RU", "SE", "SG", "SK", "TH",
    "TR", "TW", "UA", "US", "VN", "ZA",
}

# Countries on the FCC regulatory domain restrict 2.4 GHz to channels
# 1-11. hostapd refuses to start if asked to use channel 12 or 13 on
# any of these. Defense-in-depth: the rollback in main() is the
# load-bearing recovery, but rejecting at validation time keeps the
# bad config off disk in the first place.
FCC_COUNTRIES = frozenset({"US", "CA", "MX"})

# SSID is "any printable UTF-8" per IEEE; we restrict to a sensible
# subset so we don't hand hostapd something exotic and accidentally
# brick the AP. 32 BYTES is the IEEE 802.11 limit.
SSID_RE = re.compile(r"^[A-Za-z0-9 \-_.()\[\]]{1,32}$")
SSID_MAX_BYTES = 32

# WPA2 passphrase: 8-63 printable ASCII per WPA spec, OR empty
# (which means "open Wi-Fi", no encryption).
WIFI_PASSWORD_RE = re.compile(r"^[\x20-\x7e]{0,63}$")


def _err(msg: str) -> str:
    return msg


def validate_set(spec: dict) -> list[str]:
    errors: list[str] = []

    ssid = spec.get("ssid")
    if not isinstance(ssid, str):
        errors.append(_err("ssid: must be a string"))
    elif len(ssid.encode("utf-8")) > SSID_MAX_BYTES:
        errors.append(_err(f"ssid: must be {SSID_MAX_BYTES} bytes or fewer"))
    elif not SSID_RE.match(ssid):
        errors.append(_err(
            "ssid: only letters, digits, space, and -_.()[] allowed (1-32 chars)"
        ))

    wifi_password = spec.get("wifi_password", "")
    if not isinstance(wifi_password, str):
        errors.append(_err("wifi_password: must be a string"))
    elif wifi_password and not (8 <= len(wifi_password) <= 63):
        errors.append(_err(
            "wifi_password: must be empty (open) or 8-63 characters (WPA2)"
        ))
    elif not WIFI_PASSWORD_RE.match(wifi_password):
        errors.append(_err("wifi_password: contains non-printable characters"))

    channel = spec.get("channel", "auto")
    ch_int: int | None = None
    if channel != "auto":
        try:
            ch_int = int(channel)
        except (ValueError, TypeError):
            errors.append(_err("channel: must be 'auto' or 1-13"))
        else:
            if not (1 <= ch_int <= 13):
                errors.append(_err("channel: must be 'auto' or 1-13"))
                ch_int = None

    country = spec.get("country", "US")
    if country not in ALLOWED_COUNTRIES:
        errors.append(_err(
            f"country: must be one of {', '.join(sorted(ALLOWED_COUNTRIES))}"
        ))

    if ch_int is not None and country in FCC_COUNTRIES and ch_int > 11:
        errors.append(_err(
            f"channel: {ch_int} is not allowed in {country} "
            f"(regulatory domain restricts {country} to channels 1-11)"
        ))

    return errors


def write_config(spec: dict) -> None:
    # Pi-gen sets the conf file path under /boot/firmware on Trixie.
    # Render the four keys we manage; preserve the comment header so
    # the file is still recognizable when somebody mounts the SD card
    # and reads it.
    body = (
        "# PrepperPi boot-partition overrides.\n"
        "# Written by the admin console; lines edited here will be\n"
        "# overwritten on the next save. To restore the factory state,\n"
        "# use the 'Reset to factory defaults' button or delete this file.\n"
        "\n"
        f"SSID={spec['ssid']}\n"
        f"WIFI_PASSWORD={spec.get('wifi_password', '')}\n"
        f"CHANNEL={spec.get('channel', 'auto')}\n"
        f"COUNTRY={spec.get('country', 'US')}\n"
    )
    # Atomic: write to temp, rename onto the real path.
    tmp = CONF_FILE.with_suffix(".conf.tmp")
    tmp.write_text(body)
    tmp.chmod(0o644)
    tmp.replace(CONF_FILE)


def snapshot_config() -> bytes | None:
    """Read the current conf as bytes, or None if the file doesn't exist.
    Used by the rollback path so a failed apply can restore the prior
    state byte-for-byte (including the factory-shipped commented header
    if no admin save has happened yet)."""
    try:
        return CONF_FILE.read_bytes()
    except FileNotFoundError:
        return None


def restore_config(snapshot: bytes | None) -> None:
    """Restore the conf file from a snapshot taken before the failed
    apply. None means "no file existed" — delete to match. Atomic via
    rename, same as write_config."""
    if snapshot is None:
        if CONF_FILE.exists():
            CONF_FILE.unlink()
        return
    tmp = CONF_FILE.with_suffix(".conf.tmp")
    tmp.write_bytes(snapshot)
    tmp.chmod(0o644)
    tmp.replace(CONF_FILE)


def factory_reset_config() -> None:
    """Last-resort failsafe: delete the conf entirely.
    prepperpi-ap-configure falls back to its hard-coded defaults
    (auto SSID from MAC, open Wi-Fi, US, auto channel) when the file
    is missing — the same path the 'Reset to factory defaults' button
    takes."""
    if CONF_FILE.exists():
        CONF_FILE.unlink()


def reset_config() -> None:
    # "Reset to defaults" = remove the override file entirely so
    # prepperpi-ap-configure falls back to its hard-coded defaults
    # (auto-generated SSID from the MAC, open Wi-Fi, US, auto channel).
    if CONF_FILE.exists():
        CONF_FILE.unlink()


def restart_ap() -> None:
    # Re-run the configure oneshot first so /etc/hostapd and
    # /etc/dnsmasq.d are re-rendered from the new prepperpi.conf,
    # then bounce the daemons so they pick up the new config.
    for unit in ("prepperpi-ap-configure.service",
                 "hostapd.service",
                 "dnsmasq.service"):
        subprocess.run(
            ["systemctl", "restart", unit],
            check=True,
            timeout=20,
        )


def main() -> int:
    # Refuse to run with stdin attached to a TTY. The legitimate caller
    # is FastAPI piping JSON; a TTY here means somebody invoked us
    # interactively (confused-deputy probe) and we'd block on read().
    if sys.stdin.isatty():
        sys.stderr.write("refusing to read JSON payload from a TTY\n")
        return 2
    try:
        # Read up to MAX_STDIN_BYTES + 1 so we can tell oversize from exact-fit.
        raw = sys.stdin.read(MAX_STDIN_BYTES + 1)
        if len(raw) > MAX_STDIN_BYTES:
            sys.stderr.write(f"payload exceeds {MAX_STDIN_BYTES} bytes\n")
            return 2
        spec = json.loads(raw)
    except json.JSONDecodeError as exc:
        sys.stderr.write(f"invalid JSON on stdin: {exc}\n")
        return 2
    if not isinstance(spec, dict):
        sys.stderr.write("payload must be a JSON object\n")
        return 2

    action = spec.get("action")
    if action == "set":
        errors = validate_set(spec)
        if errors:
            for e in errors:
                sys.stderr.write(f"error: {e}\n")
            return 2
        # Layered recovery for AP brick resistance:
        #   Layer 1 — validation (above) catches known-bad combinations
        #             like FCC country + channel > 11.
        #   Layer 2 — snapshot the conf, apply, restart_ap. On failure
        #             restore the snapshot and re-run restart_ap so the
        #             AP comes back up on the prior known-good config.
        #   Layer 3 — if Layer 2's restart also fails (e.g. somebody
        #             corrupted the prior conf out-of-band), delete
        #             prepperpi.conf entirely and run restart_ap once
        #             more. prepperpi-ap-configure falls back to safe
        #             hard-coded defaults when the file is absent.
        snapshot = snapshot_config()
        try:
            write_config(spec)
            restart_ap()
        except (subprocess.CalledProcessError, OSError) as apply_exc:
            sys.stderr.write(
                f"apply failed ({apply_exc}); attempting rollback\n"
            )
            try:
                restore_config(snapshot)
                restart_ap()
                sys.stderr.write(
                    "rollback succeeded; previous config restored\n"
                )
                return 1
            except (subprocess.CalledProcessError, OSError) as rb_exc:
                sys.stderr.write(
                    f"rollback failed ({rb_exc}); falling back to factory defaults\n"
                )
                try:
                    factory_reset_config()
                    restart_ap()
                    sys.stderr.write(
                        "factory-reset failsafe succeeded; "
                        "prepperpi.conf removed and AP restarted with defaults\n"
                    )
                    return 1
                except (subprocess.CalledProcessError, OSError) as fr_exc:
                    sys.stderr.write(
                        f"factory-reset failsafe failed ({fr_exc}); "
                        "manual recovery required\n"
                    )
                    return 1
        sys.stdout.write("ok\n")
        return 0
    elif action == "reset":
        try:
            reset_config()
            restart_ap()
        except subprocess.CalledProcessError as exc:
            sys.stderr.write(f"systemctl failed: {exc}\n")
            return 1
        except OSError as exc:
            sys.stderr.write(f"unlink failed: {exc}\n")
            return 1
        sys.stdout.write("ok\n")
        return 0
    else:
        sys.stderr.write(f"unknown action: {action!r}\n")
        return 2


if __name__ == "__main__":
    sys.exit(main())
